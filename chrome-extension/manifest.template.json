{
  "manifest_version": 3,
  "name": "NBJ Condenser",
  "version": "0.0.0",
  "description": "Send YouTube videos to NBJ Condenser for AI-powered condensation",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*", "*://youtube.com/watch*"],
      "js": ["content-mode-flag.js", "build-info.js", "popup.js", "content.js"],
      "css": ["popup.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.css", "popup.js", "build-info.js", "content-mode-flag.js"],
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
