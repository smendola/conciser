<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: mirrors Chrome's <h2>🎬 NBJ Condenser</h2> -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_video"
                android:contentDescription="@string/app_icon"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

        </LinearLayout>

        <!-- Video info: mirrors Chrome's <div class="video-info"> -->
        <TextView
            android:id="@+id/tvVideoInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="8dp"
            android:background="#F5F5F5"
            android:text="@string/waiting_for_video"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            tools:text="Video: dQw4w9WgXcQ" />

        <!-- Mode selector: Condense vs Takeaways (mirrors Chrome extension tabs) -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:checkedButton="@id/btnModeCondense"
            app:singleLine="true"
            app:singleSelection="true"
            app:selectionRequired="true">

            <Button
                android:id="@+id/btnModeCondense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Condense"
                android:textColor="@color/mode_toggle_text_color"
                android:backgroundTint="@color/mode_toggle_bg_tint"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btnModeTakeaways"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Takeaways"
                android:textColor="@color/mode_toggle_text_color"
                android:backgroundTint="@color/mode_toggle_bg_tint"
                style="?attr/materialButtonOutlinedStyle" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Condense settings panel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCondenseSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#F8F9FA"
            app:cardElevation="0dp"
            app:cardCornerRadius="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Video Mode -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/video_mode"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleVideoMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    app:checkedButton="@id/btnVideoModeSlideshow"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <Button
                        android:id="@+id/btnVideoModeSlideshow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="🎞️ + 🗣️"
                        android:textSize="28sp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <Button
                        android:id="@+id/btnVideoModeText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📄"
                        android:textSize="28sp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Language & Voice -->
                <LinearLayout
                    android:id="@+id/layoutCondenseVoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/language"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <Spinner
                            android:id="@+id/spinnerLocale"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:spinnerMode="dialog" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <Spinner
                            android:id="@+id/spinnerVoice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:spinnerMode="dialog" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Aggressiveness -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/aggressiveness"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvAggressivenessValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbarAggressiveness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="9"
                    android:progressTint="@color/primary"
                    android:thumbTint="@color/primary" />

                <TextView
                    android:id="@+id/tvStrategyDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="italic"
                    tools:text="keep ~40% of content" />

                <!-- Speech Speed -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/speech_speed"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvSpeechSpeedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.10x"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbarSpeechSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="110"
                    android:progressTint="@color/primary"
                    android:thumbTint="@color/primary" />

                <!-- Prepend intro toggle -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchPrependIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/prepend_intro"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Takeaways settings panel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTakeawaysSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#F8F9FA"
            app:cardElevation="0dp"
            app:cardCornerRadius="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Number of Takeaways -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number of Takeaways"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleTakeawaysTop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <Button
                        android:id="@+id/btnTakeawaysTop3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="3"
                        android:textSize="12sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:minHeight="36dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <Button
                        android:id="@+id/btnTakeawaysTop5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="5"
                        android:textSize="12sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:minHeight="36dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <Button
                        android:id="@+id/btnTakeawaysTop10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="10"
                        android:textSize="12sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:minHeight="36dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <Button
                        android:id="@+id/btnTakeawaysTopAuto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto"
                        android:textSize="12sp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:minHeight="36dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Language & Voice (hidden - takeaways is text-only) -->
                <LinearLayout
                    android:id="@+id/layoutTakeawaysVoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/language"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <Spinner
                            android:id="@+id/spinnerTakeawaysLocale"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:spinnerMode="dialog" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <Spinner
                            android:id="@+id/spinnerTakeawaysVoice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:spinnerMode="dialog" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Condense button: mirrors Chrome's <button id="condenseBtn">
             GONE in COMPLETED state, disabled in NO_URL/SUBMITTING/PROCESSING -->
        <Button
            android:id="@+id/btnCondense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/condense_video"
            android:enabled="false"
            style="@style/Widget.Material3.Button" />

        <!-- Takeaways button -->
        <Button
            android:id="@+id/btnTakeaways"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extract Takeaways"
            android:enabled="false"
            android:visibility="gone"
            style="@style/Widget.Material3.Button" />

        <!-- Status container: mirrors Chrome's <div id="statusContainer">
             Background color is set programmatically per state.
             GONE until state becomes SUBMITTING, PROCESSING, COMPLETED, or ERROR. -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:visibility="gone">

            <!-- Main status text: mirrors Chrome's <div class="status"> -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                tools:text="Processing video..." />

            <!-- Progress detail: mirrors Chrome's <div class="progress"> — monospace, smaller -->
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:visibility="gone"
                tools:text="Transcribing audio..." />

        </LinearLayout>

        <!-- Cancel button: shown in SUBMITTING and PROCESSING states -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/cancel"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.TextButton" />

        <!-- Watch button: mirrors Chrome's <button class="download-btn">
             Shown only in COMPLETED state. Green to match Chrome's #28a745. -->
        <Button
            android:id="@+id/btnWatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/watch_video"
            android:visibility="gone"
            app:backgroundTint="@color/success"
            style="@style/Widget.Material3.Button" />

        <!-- Share button: shown in COMPLETED state alongside Watch -->
        <Button
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/share_link"
            android:visibility="gone"
            app:backgroundTint="#6c757d"
            style="@style/Widget.Material3.Button" />

        <!-- Recent jobs header — gone when list is empty -->
        <TextView
            android:id="@+id/tvRecentJobsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:text="@string/recent_jobs"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <!-- Job rows injected programmatically -->
        <LinearLayout
            android:id="@+id/layoutRecentJobs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Build timestamp -->
        <TextView
            android:id="@+id/tvBuildInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingTop="8dp"
            android:gravity="center"
            android:textSize="9sp"
            android:textColor="@color/text_secondary"
            android:text="..." />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
