# API Keys - Copy this file to .env and fill in your keys

# Groq (free Whisper transcription via whisper-large-v3 — get key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (for script condensing; also used as Whisper fallback if no Groq key)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (for script condensing - optional if using OpenAI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs (for voice cloning)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Azure Speech Services (for TTS with SSML support)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here  # e.g., eastus, westus, westeurope

# D-ID (for video generation) - OR use HeyGen
DID_API_KEY=your_did_api_key_here
# HEYGEN_API_KEY=your_heygen_api_key_here

# Configuration
DEFAULT_AGGRESSIVENESS=5
DEFAULT_OUTPUT_QUALITY=1080p
TEMP_DIR=./temp
OUTPUT_DIR=./output
YOUTUBE_COOKIE_FILE=  # optional: path to Netscape cookies.txt for YouTube bot-check bypass on remote VMs
YOUTUBE_PROXY_URL=    # optional: proxy URL for YouTube/yt-dlp (e.g., http://user:pass@host:port)
RESUME=true           # true = producion mode; false = no cache loads, always generate

# Service Preferences
TRANSCRIPTION_METHOD=chained  # youtube (YouTube API only), whisper (Whisper only), or chained (try YouTube, fallback to Whisper)
TRANSCRIPTION_SERVICE=groq    # groq (free, default) or openai (paid fallback)
CONDENSER_SERVICE=openai      # openai (default, gpt-5.2) or anthropic

# Service Provider Selection
CONDENSATION_PROVIDER=openai           # openai or anthropic for full condensation
TAKEAWAYS_EXTRACTION_PROVIDER=openai   # openai or anthropic for takeaways extraction
TTS_PROVIDER=edge                      # edge (free, default), elevenlabs (paid), or azure (paid, SSML)

# Model selection
CONDENSATION_MODEL_OPENAI=gpt-5.2
CONDENSATION_MODEL_ANTHROPIC=claude-sonnet-4.6
TAKEAWAYS_MODEL_OPENAI=gpt-5-nano
TAKEAWAYS_MODEL_ANTHROPIC=claude-haiku-4-5-20251001

# BrightData Residential Proxy Configuration
# BRIGHTDATA_ENABLED=true
# BRIGHTDATA_CUSTOMER_ID=
# BRIGHTDATA_ZONE_PASSWORD=
# BRIGHTDATA_ZONE=
# BRIGHTDATA_COUNTRY=

